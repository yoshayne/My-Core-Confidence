{
  "name": "core-confidence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "postbuild": "node scripts/write-server-package-json.mjs",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7",
    "@hono/clerk-auth": "^2.0.0",
    "@clerk/backend": "^1.18.0",
    "@clerk/clerk-react": "^5.17.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "lucide-react": "^0.468.0",
    "@mux/mux-player-react": "^3.1.1",
    "svix": "^1.45.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
